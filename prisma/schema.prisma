datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Mirrors the SQLAlchemy models in api/db/models.py
// SQLAlchemy runs create_all on startup; Prisma reads what's there.
// If starting fresh, run: npm run db:push

model User {
  id        String   @id @default(uuid())
  sessionId String   @unique @map("session_id")
  email     String?
  credits   Int      @default(20)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Analysis {
  id           String   @id @default(uuid())
  url          String
  videoId      String?  @map("video_id")
  realityScore Float?   @map("reality_score")
  label        String?
  rawResult    Json?    @map("raw_result")
  status       String   @default("complete")
  sessionId    String?  @map("session_id")
  createdAt    DateTime @default(now()) @map("created_at")

  queueItems   BrewmasterQueue[]

  @@index([url])
  @@index([sessionId])
  @@map("analyses")
}

model BrewmasterQueue {
  id         String    @id @default(uuid())
  url        String
  videoId    String?   @map("video_id")
  analysisId String?   @map("analysis_id")
  status     String    @default("pending")
  notes      String?
  sessionId  String?   @map("session_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at")

  analysis   Analysis? @relation(fields: [analysisId], references: [id])

  @@index([status])
  @@index([sessionId])
  @@map("brewmaster_queue")
}
